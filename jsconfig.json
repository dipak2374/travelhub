{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "baseUrl": "."
  },
  "include": [
    "client/src",
    "server"
  ],
  "exclude": [
    "node_modules",
    "server/node_modules",
    "client/node_modules",
    "dist",
    "build"
  ]
}
