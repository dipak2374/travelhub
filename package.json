{
  "name": "travelhub",
  "version": "1.0.0",
  "description": "TravelHub – All-in-One Travel & Booking Platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "start": "concurrently \"npm run start --prefix server\" \"npm run start --prefix client\"",
    "seed": "npm run seed --prefix server",
    "install:all": "npm install && npm install --prefix server && npm install --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "razorpay": "^2.9.5",
    "socket.io": "^4.8.1",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
